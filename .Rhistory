library(tidyverse)
# 1. Define the labels and their quadrant coordinates
quadrant_data <- data.frame(
label = c("Idea illustration", "Everyday dataviz",
"Idea generation", "Visual discovery"),
x = c(-0.5, 0.5, -0.5, 0.5),
y = c(0.5, 0.5, -0.5, -0.5)
)
# 2. Build the Matrix
ggplot(quadrant_data, aes(x, y)) +
# Create the central axes
geom_vline(xintercept = 0, color = "grey30", size = 0.8) +
geom_hline(yintercept = 0, color = "grey30", size = 0.8) +
# Add the quadrant labels
geom_text(aes(label = label), size = 5, fontface = "italic", color = "grey40") +
# Add the axis boundary labels
annotate("text", x = 0, y = 1.1, label = "DECLARATIVE", fontface = "bold", size = 5) +
annotate("text", x = 0, y = -1.1, label = "EXPLORATORY", fontface = "bold", size = 5) +
annotate("text", x = -1.2, y = 0, label = "CONCEPTUAL", fontface = "bold", size = 5, angle = 90) +
annotate("text", x = 1.2, y = 0, label = "DATA-DRIVEN", fontface = "bold", size = 5, angle = 270) +
# Styling to match your reference photos
scale_x_continuous(limits = c(-1.3, 1.3)) +
scale_y_continuous(limits = c(-1.3, 1.3)) +
theme_void() +
theme(
plot.background = element_rect(fill = "white", color = NA),
plot.margin = margin(20, 20, 20, 20),
plot.title = element_text(face = "bold", size = 16, hjust = 0.5, margin = margin(b = 20))
) +
labs(title = "THE FOUR TYPES OF DATAVIZ")
# 3. Save as PNG
# ggsave("dataviz_quadrants.png", width = 8, height = 6, dpi = 300)
library(tidyverse)
# 1. Define quadrant label positions
quadrant_data <- data.frame(
label = c("Idea illustration", "Everyday dataviz",
"Idea generation", "Visual discovery"),
x = c(-0.5, 0.5, -0.5, 0.5),
y = c(0.5, 0.5, -0.5, -0.5)
)
# 2. Build the Matrix
ggplot() +
# Central Quadrant Labels
geom_text(data = quadrant_data, aes(x, y, label = label),
size = 5, fontface = "plain", color = "grey40") +
# Vertical Axis Line (stops at +/- 0.9, labels are at +/- 1.05)
geom_segment(aes(x = 0, y = -0.9, xend = 0, yend = 0.9),
arrow = arrow(length = unit(0.15, "cm"), ends = "both"),
color = "grey30", size = 0.6) +
# Horizontal Axis Line (stops at +/- 0.85, labels are at +/- 1.15)
geom_segment(aes(x = -0.85, y = 0, xend = 0.85, yend = 0),
arrow = arrow(length = unit(0.15, "cm"), ends = "both"),
color = "grey30", size = 0.6) +
# Axis Labels (Positioned outside the line segments)
annotate("text", x = 0, y = 1.05, label = "DECLARATIVE", fontface = "bold", size = 4.5) +
annotate("text", x = 0, y = -1.05, label = "EXPLORATORY", fontface = "bold", size = 4.5) +
annotate("text", x = -1.15, y = 0, label = "CONCEPTUAL", fontface = "bold", size = 4.5) +
annotate("text", x = 1.15, y = 0, label = "DATA-DRIVEN", fontface = "bold", size = 4.5) +
# Titles and Theme
labs(
title = "THE FOUR TYPES",
subtitle = "From Good Charts by Scott Berinato"
) +
coord_cartesian(xlim = c(-1.5, 1.5), ylim = c(-1.2, 1.2)) +
theme_void() +
theme(
plot.background = element_rect(fill = "white", color = NA),
plot.title = element_text(face = "bold", size = 18, hjust = 0, margin = margin(b = 5)),
plot.subtitle = element_text(size = 11, color = "grey40", hjust = 0, margin = margin(b = 20)),
plot.margin = margin(30, 30, 30, 30)
)
